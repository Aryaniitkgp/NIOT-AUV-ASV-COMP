    <!--
      UNDERWATER VEHICLE
      1. Download the my_lrauv model (see chat instructions) into a models/
         folder next to this world file, e.g. ./models/my_lrauv/model.sdf
      2. export GZ_SIM_RESOURCE_PATH=$(pwd)/models:$GZ_SIM_RESOURCE_PATH
      3. Uncomment the include below.
    -->
    
    <include>
      <name>my_lrauv</name>
      <uri>model://my_lrauv</uri>
      <pose>-11 0 1.2 0 0 0</pose>
    </include>
   

  </world>
</sdf>
