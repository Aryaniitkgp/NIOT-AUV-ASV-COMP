<?xml version="1.0" ?>
<!--
  NIOT SAVe (Student Autonomous underwater Vehicle) competition arena
  Generated for Gazebo. SDF 1.7  (compatible with Gazebo-classic 11 and gz-sim).
  Tank 25 x 20 m, water height 2.5 m. Course runs along +X.
-->
<sdf version="1.7">
  <world name="save_arena">

    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Adding any <plugin> here disables gz-sim's auto-loaded defaults,
         so the standard trio (Physics, UserCommands, SceneBroadcaster)
         must be listed explicitly, alongside Buoyancy for underwater sim. -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics">
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <!-- Buoyancy: GRADED mode so buoyant force only exists BELOW the water
         surface. The water box spans z=0..2.5, so the surface is at z=2.5.
         Above 2.5 the density is ~air (1 kg/m^3) => the vehicle regains its
         weight and gravity pulls it back down, instead of the old uniform
         mode which kept a neutrally-buoyant hull weightless even in the sky.
         <enable> restricts the (more expensive) graded calc to the vehicle. -->
    <plugin filename="gz-sim-buoyancy-system" name="gz::sim::systems::Buoyancy">
      <graded_buoyancy>
        <default_density>1000</default_density>   <!-- water, below the surface -->
        <density_change>
          <above_depth>2.5</above_depth>          <!-- z of the water surface -->
          <density>1</density>                    <!-- air, above the surface -->
        </density_change>
      </graded_buoyancy>
      <enable>my_lrauv</enable>
    </plugin>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.3 0.55 0.75 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 12 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.3 -0.9</direction>
    </light>





